{
  "openapi": "3.0.0",
  "info": {
    "title": "Motors Connect API - Driver",
    "description": "Documentação completa da API para o aplicativo de motoristas do Motors Connect.",
    "version": "1.0.0",
    "contact": {
      "name": "Suporte Motors Connect",
      "email": "logistica.robertmarinho@gmail.com"
    }
  },
  "servers": [
    {
      "url": "https://motors-connect-api.vercel.app",
      "description": "Servidor de Produção"
    },
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Login": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "Register": {
        "type": "object",
        "required": ["email", "password", "nome"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" },
          "nome": { "type": "string" },
          "cpf": { "type": "string" },
          "telefone": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login de usuário",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Login" }
            }
          }
        },
        "responses": {
          "200": { "description": "Login bem-sucedido" },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Cadastro de motorista",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Register" }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário criado com sucesso" },
          "400": { "description": "Erro na validação dos dados" }
        }
      }
    },
    "/api/motorista/me": {
      "get": {
        "tags": ["Motorista"],
        "summary": "Obter perfil do motorista logado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Dados do perfil" },
          "401": { "description": "Não autorizado" }
        }
      }
    },
    "/api/motorista/ordens": {
      "get": {
        "tags": ["Ordens de Serviço"],
        "summary": "Listar ordens de serviço do motorista",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de ordens" }
        }
      }
    },
    "/api/motorista/ordens/{id}": {
      "get": {
        "tags": ["Ordens de Serviço"],
        "summary": "Detalhes de uma ordem específica",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Detalhes da ordem" }
        }
      }
    },
    "/api/motorista/ordens/{id}/status": {
      "patch": {
        "tags": ["Ordens de Serviço"],
        "summary": "Atualizar status da ordem (Check-in/out)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["agendada", "pendente", "em_andamento", "concluido", "cancelado"] },
                  "km_inicial": { "type": "number" },
                  "km_final": { "type": "number" },
                  "horario_inicio": { "type": "string" },
                  "horario_fim": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Status atualizado" }
        }
      }
    },
    "/api/motorista/ganhos": {
      "get": {
        "tags": ["Financeiro"],
        "summary": "Resumo de ganhos do motorista",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Resumo financeiro" }
        }
      }
    }
  }
}
